---
const { title = "Rosalyn Jeon" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>

  <body>
    <main>
      <nav>
        <a href="/">Rosalyn Jeon</a>
        <div>
          <a href="/">Home</a>
          <a href="/blog">Blog</a>
        </div>
      </nav>

      <slot />
    </main>
  </body>
</html>

<style is:global>
  body {
    margin: 0;
    min-height: 100%;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: #111;
    background:
      radial-gradient(circle at top right, rgba(255, 202, 235, 0.9), transparent 35%),
      radial-gradient(circle at bottom left, rgba(210, 220, 255, 0.8), transparent 35%),
      #fafafa;
  }

  main {
    width: min(1120px, calc(100% - 40px));
    margin: 0 auto;
    padding: 32px 0 96px;
  }

  nav {
    display: flex;
    justify-content: space-between;
    margin-bottom: 96px;
  }

  nav a {
    color: #111;
    text-decoration: none;
    font-weight: 600;
  }

  nav div {
    display: flex;
    gap: 24px;
  }

  .eyebrow {
    color: #9ca3af;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 13px;
  }

  h1 {
    font-size: clamp(42px, 7vw, 76px);
    line-height: 0.98;
    letter-spacing: -0.06em;
  }
</style>