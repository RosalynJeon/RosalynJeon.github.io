<style>
  :global(*) {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: #111;
    background:
      radial-gradient(circle at top right, rgba(255, 202, 235, 0.9), transparent 35%),
      radial-gradient(circle at bottom left, rgba(210, 220, 255, 0.8), transparent 35%),
      #fafafa;
  }

  main {
    width: min(1120px, calc(100% - 40px));
    margin: 0 auto;
    padding: 32px 0 80px;
  }

  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 120px;
  }

  nav a {
    color: #111;
    text-decoration: none;
    font-weight: 600;
  }

  nav div {
    display: flex;
    gap: 24px;
  }

  .hero {
    max-width: 920px;
    margin-bottom: 120px;
  }

  .eyebrow {
    color: #6b7280;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 13px;
  }

  h1 {
    font-size: clamp(48px, 8vw, 96px);
    line-height: 0.95;
    letter-spacing: -0.07em;
    margin: 20px 0 28px;
  }

  .intro {
    max-width: 680px;
    color: #4b5563;
    font-size: 22px;
    line-height: 1.5;
  }

  h2 {
    font-size: 34px;
    letter-spacing: -0.04em;
    margin-bottom: 24px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  article,
  .note {
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(17, 17, 17, 0.08);
    border-radius: 28px;
    padding: 28px;
    box-shadow: 0 20px 60px rgba(17, 17, 17, 0.06);
    backdrop-filter: blur(18px);
  }

  article span {
    color: #9ca3af;
    font-weight: 700;
  }

  article h3 {
    font-size: 26px;
    margin: 40px 0 12px;
  }

  article p,
  .note p {
    color: #4b5563;
    line-height: 1.6;
  }

  section {
    margin-bottom: 88px;
  }

  @media (max-width: 760px) {
    nav {
      align-items: flex-start;
      gap: 20px;
      flex-direction: column;
      margin-bottom: 80px;
    }

    nav div {
      flex-wrap: wrap;
    }

    .grid {
      grid-template-columns: 1fr;
    }

    .intro {
      font-size: 18px;
    }
  }
</style>
